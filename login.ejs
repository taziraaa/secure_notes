<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Secure Notes</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #1a1a2e; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .container { background: #16213e; padding: 40px; border-radius: 12px; width: 400px; box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
        h1 { color: #e94560; text-align: center; margin-bottom: 8px; }
        p.subtitle { color: #888; text-align: center; margin-bottom: 30px; font-size: 14px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; color: #ccc; margin-bottom: 6px; font-size: 14px; }
        input { width: 100%; padding: 12px; background: #0f3460; border: 1px solid #333; border-radius: 8px; color: #fff; font-size: 14px; }
        input:focus { outline: none; border-color: #e94560; }
        button { width: 100%; padding: 12px; background: #e94560; border: none; border-radius: 8px; color: #fff; font-size: 16px; cursor: pointer; font-weight: bold; }
        button:hover { background: #c73652; }
        .error { background: #ff4444; color: white; padding: 10px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; }
        .link { text-align: center; margin-top: 20px; color: #888; font-size: 14px; }
        .link a { color: #e94560; text-decoration: none; }
        .badge { text-align: center; margin-bottom: 20px; }
        .badge span { background: #0f3460; color: #e94560; padding: 4px 12px; border-radius: 20px; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🔐 Secure Notes</h1>
        <p class="subtitle">Catatan Terenkripsi AES-256</p>
        <div class="badge"><span>🔒 Dilindungi enkripsi AES-256 CBC</span></div>
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        <form method="POST" action="/auth/login">
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="Masukkan email" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Masukkan password" required>
            </div>
            <button type="submit">Login</button>
        </form>
        <div class="link">Belum punya akun? <a href="/auth/register">Daftar di sini</a></div>
    </div>
</body>
</html>